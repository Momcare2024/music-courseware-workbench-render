# VectorEngine / OpenAI-compatible gateway
VECTORENGINE_API_KEY=
VECTORENGINE_BASE_URL=https://api.vectorengine.ai/v1

# Pick models available in your VectorEngine account.
TEXT_MODEL=claude-sonnet-4-5
IMAGE_MODEL=doubao-seedream-4-5-251128

# Volcengine Ark image generation.
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_IMAGE_MODEL=doubao-seedream-4-0-250828

# Optional simple password for shared cloud use.
ACCESS_CODE=

# Set false on Render so friends cannot edit API keys in the page.
ALLOW_WEB_CONFIG=true

# Optional: point to the installed PPT Master clone for local experiments.
PPT_MASTER_ROOT=./ppt-master

# Local data directory for projects and generated artifacts.
WORKBENCH_DATA_DIR=./data
